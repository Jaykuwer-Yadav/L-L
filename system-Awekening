<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>System - Awakening Evaluation</title>
    <style>
      body {
        background-color: #0a0a0b;
        color: #e0e0e0;
        font-family: 'Segoe UI', 'Courier New', monospace;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
      }

      .system-container { 
        background: rgba(16, 22, 34, 0.95);
        border: 2px solid #00d4ff;
        box-shadow: 0 0 25px rgba(0, 212, 255, 0.2);
        padding: 30px; 
        width: 400px;
        border-radius: 4px;
      }

      h2 { color: #00d4ff; text-transform: uppercase; letter-spacing: 3px; text-align: center; border-bottom: 1px solid #00d4ff; padding-bottom: 15px; margin-top: 0; }

      .status-header {
        display: flex;
        justify-content: space-between;
        font-weight: bold;
        color: #888;
        margin-bottom: 20px;
        text-transform: uppercase;
      }

      .current-rank { color: #fff; border: 1px solid #fff; padding: 2px 8px; }

      label { display: block; margin-top: 15px; font-size: 0.75rem; color: #00d4ff; text-transform: uppercase; }

      input {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid #30363d;
        color: #fff;
        padding: 12px;
        width: 100%;
        margin-top: 5px;
        box-sizing: border-box;
        outline: none;
      }

      input:focus { border-color: #00d4ff; }

      button {
        background: #00d4ff;
        color: #000;
        border: none;
        padding: 15px;
        width: 100%;
        margin-top: 25px;
        font-weight: bold;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
      }

      button:hover { background: #fff; box-shadow: 0 0 15px #00d4ff; }

      /* Hidden Result Window */
      #quest-window {
        margin-top: 25px;
        padding: 20px;
        border: 1px solid #ff4444;
        background: rgba(255, 68, 68, 0.05);
        display: none;
        animation: fadeIn 0.5s;
      }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .rank-display { font-size: 2.2rem; font-weight: 900; display: block; margin: 10px 0; text-align: center; }
      
      /* Rank Colors */
      .S-Rank { color: #f1e05a; text-shadow: 0 0 15px #f1e05a; }
      .B-Rank { color: #a371f7; text-shadow: 0 0 10px #a371f7; }
      .E-Rank { color: #8b949e; }
      
      .warning { color: #ff4444; font-weight: bold; font-size: 0.8rem; text-align: center; display: block; }
      .quest-text { font-size: 0.9rem; line-height: 1.5; margin-top: 10px; color: #ccc; }
    </style>
  </head>
  <body>

    <div class="system-container">
      <div class="status-header">
        <span>Status: <span id="status-tag">Awakening...</span></span>
        <span class="current-rank" id="rank-tag">UNRANKED</span>
      </div>

      <h2>[ Player Evaluation ]</h2>
      
      <label>Hunter Name</label>
      <input type="text" id="UserName" placeholder="Enter name..." />
      
      <label>Push-ups (Repetitions)</label>
      <input type="number" id="pushups" placeholder="0" />
      
      <label>Squats (Repetitions)</label>
      <input type="number" id="squats" placeholder="0" />

      <label>Running (KM in 30 Min)</label>
      <input type="number" id="running" placeholder="0" />

      <button onclick="awakenPlayer()">Submit Stats for Evaluation</button>

      <div id="quest-window">
        <span class="warning">! EVALUATION COMPLETE !</span>
        <span id="rank-result" class="rank-display"></span>
        <p class="quest-text" id="quest-desc"></p>
        <p style="font-size: 0.65rem; color: #666; text-align: center; margin-top: 15px;">
            *Penalty Quest will trigger if Daily Goals are not met.*
        </p>
      </div>
    </div>

    <script>
      function awakenPlayer() {
        // Get Inputs
        const name = document.getElementById('UserName').value || "Unknown";
        const p = parseInt(document.getElementById('pushups').value) || 0;
        const s = parseInt(document.getElementById('squats').value) || 0;
        const r = parseFloat(document.getElementById('running').value) || 0;

        // UI Elements
        const rankTag = document.getElementById('rank-tag');
        const statusTag = document.getElementById('status-tag');
        const rankResult = document.getElementById('rank-result');
        const questDesc = document.getElementById('quest-desc');
        const questWindow = document.getElementById('quest-window');

        let rank = "";
        let colorClass = "";
        let dailyQuest = "";

        // Logic Evaluation
        if (p >= 50 && s >= 50 && r >= 5) {
          rank = "S-RANK";
          colorClass = "S-Rank";
          dailyQuest = `Elite Hunter ${name}, your quest is to clear the Instant Dungeon: 500 reps of each set and 40km of running. Only the strong survive.`;
        } else if (p >= 20 && s >= 20 && r >= 2) {
          rank = "B-RANK";
          colorClass = "B-Rank";
          dailyQuest = `Hunter ${name}, high-tier training assigned: 200 Push-ups, 200 Squats, and 15km of road work.`;
        } else {
          rank = "E-RANK";
          colorClass = "E-Rank";
          dailyQuest = `Hunter ${name}, the World's Weakest. Complete 100 Push-ups, 100 Sit-ups, 100 Squats, and 10km Running to avoid the Penalty Zone.`;
        }

        // Update System UI
        statusTag.innerText = "ACTIVE";
        statusTag.style.color = "#00d4ff";
        rankTag.innerText = rank;
        rankTag.className = `current-rank ${colorClass}`;
        
        rankResult.innerText = rank;
        rankResult.className = `rank-display ${colorClass}`;
        questDesc.innerHTML = `<strong>[DAILY QUEST ARRIVED]</strong><br><br>${dailyQuest}`;
        
        questWindow.style.display = "block";
      }
    </script>
  </body>
</html>